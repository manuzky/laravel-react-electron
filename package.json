{
  "name": "desktopapp",
  "version": "1.0.0",
  "description": "Descripción de la app",
  "author": "JMCP",
  "$schema": "https://www.schemastore.org/package.json",
  "private": true,
  "type": "module",
  "main": "mainElectron.cjs",
  "scripts": {
    "dev": "vite",
    "start": "electron .",
    "web": "concurrently -k -n server,client \"php server/artisan serve\" \"cd client && npm run dev\"",
    "build": "cd client && npm run build",
    "predist": "npm run build",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.application.app",
    "productName": "laravelElectronApp",
    "directories": {
      "output": "dist"
    },
    "asar": false,
    "compression": "maximum",
    "files": [
      "mainElectron.cjs",
      "client/dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "server",
        "to": "app",
        "filter": [
          "app/**/*",
          "bootstrap/**/*",
          "config/**/*",
          "database/**/*",
          "public/**/*",
          "resources/**/*",
          "routes/**/*",
          "storage/app/**/*",
          "storage/framework/**/*",
          "vendor/**/*",
          "artisan",
          ".env",
          "composer.json",
          "!node_modules",
          "!tests",
          "!storage/logs/*"
        ]
      },
      {
        "from": "server/php",
        "to": "php"
      },
      {
      "from": "client/dist",
      "to": "client"
     }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.2",
    "@tailwindcss/vite": "^4.0.0",
    "alpinejs": "^3.4.2",
    "autoprefixer": "^10.4.2",
    "axios": "^1.11.0",
    "concurrently": "^9.0.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "laravel-vite-plugin": "^3.0.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.1.0",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "tree-kill": "^1.2.2"
  }
}